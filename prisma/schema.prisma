// Prisma schema for Phase 2 — Organizations, Users, Projects, Resources, AuditLog
// Datasource uses an environment variable DATABASE_URL
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users     User[]
  projects  Project[]
  // audit logs referencing this org
  auditLogs AuditLog[]

  @@map("organizations")
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String
  name           String?
  role           String   @default("member")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@map("users")
}

model Project {
  id             String    @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  resources      Resource[]

  @@index([organizationId])
  @@map("projects")
}

model Resource {
  id             String    @id @default(uuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  type           String
  attributes     Json?
  deletedAt      DateTime?
  version        Int       @default(1)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@map("resources")
}

model AuditLog {
  id           String   @id @default(uuid())
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id])
  resourceType String
  resourceId   String
  action       String
  actorId      String?
  before       Json?
  after        Json?
  createdAt    DateTime @default(now())

  @@index([organizationId])
  @@index([resourceId])
  @@map("audit_logs")
}
