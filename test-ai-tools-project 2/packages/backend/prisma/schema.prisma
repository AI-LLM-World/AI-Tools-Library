generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Minimal Tool model for the AI tools catalog. Adjust as product needs evolve.
model Tool {
  // We use a string id that matches the `id` values in data/ai_tools.json (slug-like)
  id               String   @id
  name             String
  category         String?
  shortDescription String?  @map("short_description")
  website          String?
  tags             Json?
  exampleUse       String?  @map("example_use")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
}
