// Prisma schema for Phase 2 / Phase 3 initial models
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Organization {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users     User[]
  projects  Project[]
  auditLogs AuditLog[]
}

model User {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  email          String
  password       String
  name           String?
  role           String   @default("member")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@unique([organizationId, email])
}

model Project {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  resources      Resource[]

  @@index([organizationId])
  @@unique([organizationId, name])
}

model Resource {
  id             String   @id @default(uuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  type           String
  attributes     Json?
  version        Int      @default(1)
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  auditLogs      AuditLog[]

  @@index([organizationId, projectId])
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String
  resourceType   String
  resourceId     String?
  action         String
  actorId        String?
  before         Json?
  after          Json?
  createdAt      DateTime @default(now())

  @@index([organizationId, resourceId])
}
